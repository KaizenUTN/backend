        created_at:
          type: string
          format: date-time
          readOnly: true
          title: Fecha de creación
        updated_at:
          type: string
          format: date-time
          readOnly: true
          title: Última actualización
      required:
      - created_at
      - email
      - full_name
      - id
      - is_active
      - updated_at
  securitySchemes:
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
tags:
- name: Autenticación
  description: Registro, login, logout y renovación de tokens JWT.
- name: Perfil
  description: Ver y editar el perfil del usuario autenticado. Cambio de contraseña.
- name: Usuarios
  description: |-
    Gestión administrativa de cuentas: listar, crear, editar, desactivar y resetear contraseña.

    | Permiso requerido | Operación |
    |-------------------|-----------|
    | `usuarios.view` | Listar / Ver |
    | `usuarios.create` | Crear |
    | `usuarios.edit` | Editar / Reset contraseña |
    | `usuarios.delete` | Desactivar |
