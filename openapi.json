              schema:
                $ref: '#/components/schemas/OrderNotFoundResponse'
          description: La orden con el ID proporcionado no existe.
  /api/trading/orders/{order_id}/cancel/:
    post:
      operationId: brokerage_orders_cancel
      description: |-
        Cancela una orden en estado `PENDING` o `PARTIAL`.

        No se puede cancelar una orden `FILLED` o ya `CANCELLED`.
      summary: Cancelar orden
      parameters:
      - in: path
        name: order_id
        schema:
          type: integer
        required: true
      tags:
      - Trading
      security:
      - jwtAuth: []
      - bearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Order'
          description: Orden cancelada. El campo `status` será `CANCELLED`.
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderCancelError'
          description: La orden no puede cancelarse en su estado actual.
        '401':
          description: 'No autenticado. Se requiere JWT válido en el header `Authorization:
            Bearer <token>`.'
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OrderNotFoundResponse'
          description: La orden con el ID proporcionado no existe.
  /api/trading/transactions/:
    get:
      operationId: brokerage_transactions_list
      description: |-
        Retorna todas las transacciones registradas, ordenadas por fecha descendente.

        Una **Transacción** es un hecho contable ejecutado e **inmutable**. Representa la liquidación real de una operación financiera. El campo `total` (precio unitario × cantidad) se calcula en tiempo real y no está almacenado en la base de datos.
      summary: Listar transacciones
      tags:
      - Trading
      security:
      - jwtAuth: []
      - bearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Transaction'
          description: Lista de transacciones.
        '401':
          description: 'No autenticado. Se requiere JWT válido en el header `Authorization:
            Bearer <token>`.'
    post:
      operationId: brokerage_transactions_create
      description: |-
        Registra una nueva transacción contable ejecutada.

        **Inmutabilidad:** una vez creada, la transacción no puede modificarse ni eliminarse. Para revertir una operación, crear una nueva transacción de signo contrario.

        **Validaciones:**
        - El cliente debe estar en estado `ACTIVE`.
        - `unit_price` y `quantity` deben ser mayores a cero.
        - `order_id` es opcional (transacciones OTC o directas sin orden previa).
      summary: Registrar transacción
      tags:
      - Trading
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TransactionCreateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TransactionCreateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TransactionCreateRequest'
        required: true
      security:
      - jwtAuth: []
      - bearerAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Transaction'
              examples:
                CompraDeBTC:
                  value:
                    id: 1
                    client_id: 3
                    client_cuit: 20-12345678-9
                    order_id: 1
                    asset_code: BTC
                    fiat_currency_code: ARS
                    transaction_type: BUY
                    unit_price: '50000000.00000000'
                    quantity: '0.01000000'
                    total: '500000.00000000'
                    status: CONFIRMED
                    blockchain_hash: null
                    created_at: '2026-02-20T14:35:00Z'
                  summary: Compra de BTC
          description: Transacción registrada con estado `CONFIRMED`.
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/BrokerageValidationErrorResponse'
          description: |-
            Datos de entrada inválidos. El cuerpo incluye un objeto con los campos que fallaron y una lista de mensajes descriptivos por campo.

            Ejemplo: `{"cuit": ["Ya existe un cliente con CUIT '20-12345678-9'."]}`
        '401':
          description: 'No autenticado. Se requiere JWT válido en el header `Authorization:
            Bearer <token>`.'
  /api/trading/transactions/{tx_id}/:
    get:
      operationId: brokerage_transactions_retrieve
      summary: Obtener detalle de una transacción
      parameters:
      - in: path
        name: tx_id
        schema:
          type: integer
        required: true
      tags:
      - Trading
      security:
      - jwtAuth: []
      - bearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Transaction'
              examples:
                CompraDeBTC:
                  value:
                    id: 1
                    client_id: 3
                    client_cuit: 20-12345678-9
                    order_id: 1
                    asset_code: BTC
                    fiat_currency_code: ARS
                    transaction_type: BUY
                    unit_price: '50000000.00000000'
                    quantity: '0.01000000'
                    total: '500000.00000000'
                    status: CONFIRMED
                    blockchain_hash: null
                    created_at: '2026-02-20T14:35:00Z'
                  summary: Compra de BTC
          description: ''
        '401':
          description: 'No autenticado. Se requiere JWT válido en el header `Authorization:
            Bearer <token>`.'
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TxNotFoundResponse'
          description: La transacción con el ID proporcionado no existe.
components:
  schemas:
    AdminCreateUserRequest:
      type: object
      description: |-
        Valida datos para el alta administrativa de un usuario.
        Role es opcional; si no se provee, el usuario queda sin rol asignado.
      properties:
        email:
          type: string
          format: email
          minLength: 1
        first_name:
          type: string
          minLength: 1
          maxLength: 150
        last_name:
          type: string
          minLength: 1
          maxLength: 150
        password:
          type: string
          writeOnly: true
          minLength: 8
        role_id:
          type: integer
          nullable: true
        is_active:
          type: boolean
          default: true
      required:
      - email
      - first_name
      - last_name
      - password
    AdminPanelResponse:
      type: object
      properties:
        panel:
          type: string
          description: Estado del panel.
      required:
      - panel
    AdminUser:
      type: object
      description: |-
        Representación completa de un usuario para endpoints administrativos.
        Incluye role_name como campo de solo lectura para evitar un join adicional en el frontend.
        No expone password ni token_version.
      properties:
        id:
          type: integer
          readOnly: true
        email:
          type: string
          format: email
          readOnly: true
        first_name:
          type: string
          readOnly: true
        last_name:
          type: string
          readOnly: true
        full_name:
          type: string
          readOnly: true
        role:
          type: integer
          readOnly: true
          nullable: true
          title: Rol
        role_name:
          type: string
          readOnly: true
        is_active:
          type: boolean
          readOnly: true
          title: Active
          description: Designates whether this user should be treated as active. Unselect
            this instead of deleting accounts.
        created_at:
          type: string
          format: date-time
          readOnly: true
          title: Fecha de creación
        updated_at:
          type: string
          format: date-time
          readOnly: true
          title: Última actualización
      required:
      - created_at
      - email
      - first_name
      - full_name
      - id
      - is_active
      - last_name
      - role
      - role_name
      - updated_at
    Asset:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        code:
          type: string
        name:
          type: string
        is_active:
          type: boolean
      required:
      - code
      - id
      - is_active
      - name
    AssetCreateRequest:
      type: object
      properties:
        code:
          type: string
          minLength: 1
          maxLength: 20
        name:
          type: string
          default: ''
          maxLength: 100
      required:
      - code
    AssetNotFoundResponse:
      type: object
      properties:
        error:
          type: string
          default: Activo no encontrado.
    AuditBadFilterResponse:
      type: object
      properties:
        status:
          type: array
          items:
            type: string
          default:
          - Seleccione una opción válida. "INVALID" no está disponible.
        user_id:
          type: array
          items:
            type: string
          default:
          - Introduzca un número entero válido.
    AuditForbiddenResponse:
      type: object
      properties:
        detail:
          type: string
          default: 'Permiso denegado. Se requiere: ''auditoria.view''.'
    AuditLog:
      type: object
      description: |-
        Serializer de lectura para AuditLog.

        El campo `user` muestra id + email en lugar del PK crudo.
        El campo `status_display` expone la etiqueta legible del choice.
      properties:
        id:
          type: integer
          readOnly: true
        user:
          allOf:
          - $ref: '#/components/schemas/AuditLogUser'
          readOnly: true
        action:
          type: string
          readOnly: true
          title: Acción
          description: 'Identificador de la acción. Convención: "<recurso>.<verbo>"
            — ej: "user.created".'
        resource:
          type: string
          readOnly: true
          title: Recurso
          description: 'Tipo de recurso afectado. Ej: "user", "payment", "report".'
        resource_id:
          type: string
          readOnly: true
          title: ID del recurso
          description: Identificador del recurso específico afectado (opcional).
        status:
          allOf:
          - $ref: '#/components/schemas/AuditLogStatusEnum'
          readOnly: true
          title: Estado
        status_display:
          type: string
          readOnly: true
        metadata:
          readOnly: true
          description: 'Contexto adicional en formato JSON. NUNCA incluir datos sensibles:
            passwords, tokens, claves privadas.'
        ip_address:
          type: string
          readOnly: true
          nullable: true
          title: Dirección IP
          description: IP de origen de la solicitud.
        user_agent:
          type: string
          readOnly: true
          description: Identificación del cliente HTTP.
        timestamp:
          type: string
          format: date-time
          readOnly: true
          description: Fecha y hora UTC de creación. Inmutable.
        correlation_id:
          type: string
          format: uuid
          readOnly: true
          description: UUID que correlaciona múltiples eventos de una misma operación.
            Útil para trazabilidad en arquitecturas orientadas a eventos.
      required:
      - action
      - correlation_id
      - id
      - ip_address
      - metadata
      - resource
      - resource_id
      - status
      - status_display
      - timestamp
      - user
      - user_agent
    AuditLogStatusEnum:
      enum:
      - SUCCESS
      - FAILURE
      type: string
      description: |-
        * `SUCCESS` - Exitoso
        * `FAILURE` - Fallido
    AuditLogUser:
      type: object
      description: Representación mínima del usuario asociado al log.
      properties:
        id:
          type: integer
          readOnly: true
        email:
          type: string
          format: email
          readOnly: true
      required:
      - email
      - id
    AuditNotFoundResponse:
      type: object
      properties:
        detail:
          type: string
          default: No encontrado.
    AuthTokenResponse:
      type: object
      properties:
        access:
          type: string
          description: 'JWT access token. Válido por 10 minutos. Incluirlo en el header:
            Authorization: Bearer <token>'
        refresh:
          type: string
          description: JWT refresh token. Válido por 7 días. Usarlo en /api/auth/refresh/
            para obtener un nuevo access token.
        user:
          $ref: '#/components/schemas/User'
      required:
      - access
      - refresh
      - user
    BrokerageValidationErrorResponse:
      type: object
      properties:
        cuit:
          type: array
          items:
            type: string
        name:
          type: array
          items:
            type: string
        code:
          type: array
          items:
            type: string
    ChangePasswordRequest:
      type: object
      description: Serializer for changing user password
      properties:
        old_password:
          type: string
          writeOnly: true
          minLength: 1
        new_password:
          type: string
          writeOnly: true
          minLength: 1
        new_password_confirm:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - new_password
      - new_password_confirm
      - old_password
    Client:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        cuit:
          type: string
        name:
          type: string
        email:
          type: string
          format: email
        status:
          $ref: '#/components/schemas/ClientStatusEnum'
        is_active:
          type: boolean
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
